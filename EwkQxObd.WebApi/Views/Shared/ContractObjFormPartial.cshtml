@model EqoContractObject

@{
    
}


    <div class="row mb-3">
        <h3 class="col-8 pe-3">IQX Contract</h3>
    </div>

    <partial name="ContractFormPartial" for="Contract"/>



    <div class="row mb-3 mt-5">
        <h3 class="col-sm-8">Ship-To</h3>
    </div>


    <partial name="AccountFormPartial" for="ShipTo" />

@if (Model is not null && Model.InstrumentConnected is not null)
{
    <partial name="SyngioDetailsPartial" model="Model.InstrumentConnected" />
} 
else
{
    <div class="row mb-3 mt-5">
        <h3 class="col-8 me-5">Instrument</h3>
    </div>

    <div class="row mb-3">
        <div class="col-2">

            <label class="form-label">Serial Number</label>
        </div>
        <div class="col-4">
            <input id="inpSerialNo" class="form-control" type="text" asp-for="SerialNumber" placeholder="Enter instrument S/N, i.e. 987654321" />
        </div>
        <div class="valid-feedback">
            Validated.
        </div>
        <div class="invalid-feedback">
            Not a valid Serial Number
        </div>
    </div>


    <div class="row mb-3">
        <div class="col-3">
            <label class="form-label">Instrument Type</label>
        </div>
        <div class="col-8">
            <select id="sltInstFamily" class="form-select" aria-label="Select Instrument Family">
                <option selected>Select Business Unit</option>
            </select>
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-3">
            
        </div>
        <div class="col-8">
            <select id="sltInstType" class="form-select" aria-label="Select Instrument Type">
                <option selected>Select Instrument Type</option>
            </select>
        </div>
    </div>
}




