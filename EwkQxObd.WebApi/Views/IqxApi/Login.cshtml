@using EwkQxObd.Api.Authentication.ObjectModel
@{
}

<div class="row justify-content-center">
    <div class="col-4">
        <h2 class="text-center"> Login to IQX API</h2>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-4 g-3">
        <form method="post" asp-action="Login">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label for="userEmailInput" class="form-label">User Name</label>
                <input type="email" class="form-control" id="username" name="username" aria-describedby="emailHelp"/>
                <div id="emailHelp" class="form-text text-end">Enter your user name here</div>
            </div>
            <div class="mb-lg-5">
                <label for="userPassInput" class="form-label">Password</label>
                <input type="password" class="form-control" id="password" name="password" />
            </div>
            <button type="submit" class="btn btn-primary w-25">Login</button>
            <a type="button" class="btn btn-warning w-25" asp-controller="Home" asp-action="Index">Cancel</a>
        </form>
    </div>
</div>