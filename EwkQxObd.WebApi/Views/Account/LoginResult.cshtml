@using EwkQxObd.WebApi.Models.IqxApi
@using System.Security.Claims

@model ClaimsPrincipal

@if(Model.Identity is null)
{
    <h1>Login Failed</h1>
}
else
{
    <h1>Welcome! @Model.Identity.Name</h1>
}


<div class="mt-3">
    <a class="btn btn-primary ps-5 pe-5" role="button" asp-controller="Home" asp-action="Index">Return Home</a>
</div>